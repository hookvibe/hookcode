{
  "name": "hookcode",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.6.0",
  "workspaces": [
    "backend",
    "frontend",
    "docs"
  ],
  "scripts": {
    "dev": "concurrently  \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "node scripts/run-backend-dev.cjs",
    "dev:tools": "pnpm --filter hookcode-backend dev:tools",
    "dev:frontend": "pnpm --filter hookcode-frontend dev",
    "dev:db": "docker compose -f docker/docker-compose.yml up db -d",
    "sync:worker-version": "node scripts/update-worker-version.cjs",
    "dev:doc": "pnpm --filter hookcode-docs dev",
    "build:doc": "pnpm --filter hookcode-docs build",
    "db:migrate": "pnpm --filter hookcode-backend db:migrate",
    "db:migrate:dev": "pnpm --filter hookcode-backend db:migrate:dev",
    "db:reset": "pnpm --filter hookcode-backend db:reset",
    "db:push": "pnpm --filter hookcode-backend db:push",
    "db:pull": "pnpm --filter hookcode-backend db:pull",
    "db:studio": "pnpm --filter hookcode-backend db:studio",
    "db:status": "pnpm --filter hookcode-backend db:status",
    "build:backend": "pnpm --filter hookcode-backend build",
    "build:frontend": "pnpm --filter hookcode-frontend build",
    "lint": "echo \"add lint in packages\"",
    "test": "pnpm test:root && pnpm --filter hookcode-backend test && pnpm --filter hookcode-frontend test",
    "test:root": "node --test scripts/run-backend-dev.test.cjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
