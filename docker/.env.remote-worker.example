# Dedicated remote worker example for `docker/docker-compose.remote-worker.yml`. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# 独立远程 worker 的环境变量示例，对应 `docker/docker-compose.remote-worker.yml`。

# Backend API base URL reachable from the worker host (must include `/api`). docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# 远程 worker 所在机器可访问的 backend API 地址（必须包含 `/api`）。
HOOKCODE_BACKEND_URL=https://your-hookcode.example.com/api

# Worker bootstrap id copied from Settings -> Workers. docs/en/developer/plans/external-worker-bind-existing-20260312/task_plan.md external-worker-bind-existing-20260312
# 从 Settings -> Workers 复制的 worker ID。
HOOKCODE_WORKER_ID=11111111-1111-4111-8111-111111111111

# Worker bootstrap token copied from Settings -> Workers. docs/en/developer/plans/external-worker-bind-existing-20260312/task_plan.md external-worker-bind-existing-20260312
# 从 Settings -> Workers 复制的 worker token。
HOOKCODE_WORKER_TOKEN=change-me-remote-worker-token

# Display name shown in HookCode. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# HookCode 界面中显示的 worker 名称。
HOOKCODE_WORKER_NAME=Dedicated Remote Worker

# Dedicated hosts should stay on the remote worker kind. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# 独立部署的执行器应保持 remote 类型。
HOOKCODE_WORKER_KIND=remote

# Max concurrent tasks handled by this worker. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# 当前 worker 可并发执行的任务数。
HOOKCODE_WORKER_MAX_CONCURRENCY=1

# Keep preview disabled for remote workers in v1. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# v1 中远程 worker 应保持预览能力关闭。
HOOKCODE_WORKER_PREVIEW=0

# Shared runtime storage root inside the worker container (must stay absolute). docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# worker 容器内的统一运行时根目录（必须保持绝对路径）。
HOOKCODE_WORK_DIR=/var/lib/hookcode

# Optional Prisma engines mirror used while rebuilding the worker image. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
# 重建 worker 镜像时可选的 Prisma engines 镜像地址。
PRISMA_ENGINES_MIRROR=
