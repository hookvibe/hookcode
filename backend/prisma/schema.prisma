generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id           String   @id @db.Uuid
  groupId      String?  @map("group_id") @db.Uuid
  /// Persist the execution worker chosen at enqueue time so tasks do not silently migrate. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  workerId     String?  @map("worker_id") @db.Uuid
  groupOrder   Int?     @map("group_order")
  eventType    String   @map("event_type")
  status       String
  archivedAt   DateTime? @map("archived_at") @db.Timestamptz(6)
  payload      Json?    @map("payload_json") @db.JsonB
  promptCustom String?  @map("prompt_custom")
  title        String?
  projectId    Int?     @map("project_id")
  repoProvider String?  @map("repo_provider")
  repoId       String?  @map("repo_id") @db.Uuid
  robotId      String?  @map("robot_id") @db.Uuid
  /// Track the triggering user for task notifications. docs/en/developer/plans/notify-panel-20260302/task_plan.md notify-panel-20260302
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  ref          String?
  mrId         Int?     @map("mr_id")
  issueId      Int?     @map("issue_id")
  retries      Int      @default(0)
  result       Json?    @map("result_json") @db.JsonB
  /// Persist dependency install outcomes for multi-language repos. docs/en/developer/plans/depmanimpl20260124/task_plan.md depmanimpl20260124
  dependencyResult Json? @map("dependency_result") @db.JsonB
  /// Track when backend detected that the assigned worker disappeared during execution. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  workerLostAt  DateTime? @map("worker_lost_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  group        TaskGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  /// Link task rows to the selected worker for UI attribution and dispatch. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  worker       Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  /// Access task log rows stored in task_logs for pagination. docs/en/developer/plans/task-logs-table-20260306/task_plan.md task-logs-table-20260306
  logs         TaskLog[]
  /// Track approval-gate requests so high-risk tasks can pause before execution. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
  approvalRequests ApprovalRequest[]

  @@map("tasks")
  @@index([status, createdAt], map: "tasks_status_created_at_idx")
  @@index([groupId, createdAt], map: "tasks_group_id_created_at_idx")
  @@index([groupId, groupOrder], map: "tasks_group_id_group_order_idx")
  @@index([archivedAt], map: "tasks_archived_at_idx")
  /// Accelerate worker-specific queue scans and attribution queries. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  @@index([workerId, status, createdAt], map: "tasks_worker_status_created_at_idx")
  /// Speed up repo-scoped task lists and stats with repo/status/time indexes. docs/en/developer/plans/repo-page-slow-requests-20260128/task_plan.md repo-page-slow-requests-20260128
  @@index([repoId, status, updatedAt], map: "tasks_repo_status_updated_at_idx")
  @@index([repoId, createdAt], map: "tasks_repo_created_at_idx")
  @@index([repoId, archivedAt], map: "tasks_repo_archived_at_idx")
}

/// Store task execution log lines in a separate table for pagination and performance. docs/en/developer/plans/task-logs-table-20260306/task_plan.md task-logs-table-20260306
model TaskLog {
  id        String   @id @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  seq       Int
  line      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_logs")
  @@unique([taskId, seq], map: "task_logs_task_id_seq_unique")
  @@index([taskId, seq], map: "task_logs_task_id_seq_idx")
  @@index([taskId, createdAt], map: "task_logs_task_id_created_at_idx")
}

/// Persist approval-gate requests for high-risk task executions. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model ApprovalRequest {
  id               String   @id @db.Uuid
  taskId           String   @map("task_id") @db.Uuid
  repoId           String?  @map("repo_id") @db.Uuid
  robotId          String?  @map("robot_id") @db.Uuid
  requestedByUserId String? @map("requested_by_user_id") @db.Uuid
  resolvedByUserId String?  @map("resolved_by_user_id") @db.Uuid
  status           String
  decision         String
  riskLevel        String   @map("risk_level")
  summary          String   @db.Text
  details          Json?    @map("details_json") @db.JsonB
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actions          ApprovalAction[]

  @@map("approval_requests")
  @@index([taskId, createdAt], map: "approval_requests_task_id_created_at_idx")
  @@index([status, createdAt], map: "approval_requests_status_created_at_idx")
  @@index([repoId, status, createdAt], map: "approval_requests_repo_status_created_at_idx")
}

/// Persist approval actions for audit history and queue transitions. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model ApprovalAction {
  id                String   @id @db.Uuid
  approvalRequestId String   @map("approval_request_id") @db.Uuid
  actorUserId       String?  @map("actor_user_id") @db.Uuid
  action            String
  note              String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@map("approval_actions")
  @@index([approvalRequestId, createdAt], map: "approval_actions_request_created_at_idx")
}

/// Store repo/robot scoped policy rules for approval gates and deny lists. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model PolicyRule {
  id              String   @id @db.Uuid
  repoId          String?  @map("repo_id") @db.Uuid
  robotId         String?  @map("robot_id") @db.Uuid
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  name            String
  enabled         Boolean  @default(true)
  priority        Int      @default(100)
  action          String
  conditions      Json?    @map("conditions_json") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("policy_rules")
  @@index([repoId, robotId, enabled, priority], map: "policy_rules_scope_enabled_priority_idx")
  @@index([enabled, priority, createdAt], map: "policy_rules_enabled_priority_created_at_idx")
}

/// Store budget and quota policies for user/repo/robot scopes. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model BudgetPolicy {
  id                           String   @id @db.Uuid
  scopeType                    String   @map("scope_type")
  scopeId                      String   @map("scope_id") @db.Uuid
  createdByUserId              String?  @map("created_by_user_id") @db.Uuid
  updatedByUserId              String?  @map("updated_by_user_id") @db.Uuid
  name                         String?
  enabled                      Boolean  @default(true)
  overageAction                String   @default("soft_limit") @map("overage_action")
  dailyTaskCountLimit          Int?     @map("daily_task_count_limit")
  monthlyTaskCountLimit        Int?     @map("monthly_task_count_limit")
  dailyTokenLimit              Int?     @map("daily_token_limit")
  monthlyTokenLimit            Int?     @map("monthly_token_limit")
  dailyEstimatedCostMicroUsd   BigInt?  @map("daily_estimated_cost_micro_usd")
  monthlyEstimatedCostMicroUsd BigInt?  @map("monthly_estimated_cost_micro_usd")
  maxRuntimeSeconds            Int?     @map("max_runtime_seconds")
  maxStepCount                 Int?     @map("max_step_count")
  degradeProvider              String?  @map("degrade_provider")
  degradeModel                 String?  @map("degrade_model")
  forceReadOnlyOnOverage       Boolean  @default(false) @map("force_read_only_on_overage")
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("budget_policies")
  @@unique([scopeType, scopeId], map: "budget_policies_scope_type_scope_id_unique")
  @@index([scopeType, enabled, updatedAt], map: "budget_policies_scope_enabled_updated_at_idx")
}

/// Persist daily task-usage rollups to accelerate cost dashboards and quota summaries. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model UsageDailyRollup {
  id                    String   @id @db.Uuid
  taskId                String   @unique @map("task_id") @db.Uuid
  bucketDate            DateTime @map("bucket_date") @db.Date
  repoId                String?  @map("repo_id") @db.Uuid
  robotId               String?  @map("robot_id") @db.Uuid
  actorUserId           String?  @map("actor_user_id") @db.Uuid
  provider              String?
  model                 String?
  status                String
  taskCount             Int      @default(1) @map("task_count")
  inputTokens           Int      @default(0) @map("input_tokens")
  outputTokens          Int      @default(0) @map("output_tokens")
  totalTokens           Int      @default(0) @map("total_tokens")
  estimatedCostMicroUsd BigInt   @default(0) @map("estimated_cost_micro_usd")
  durationMs            Int?     @map("duration_ms")
  failed                Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("usage_daily_rollup")
  @@index([bucketDate, repoId], map: "usage_daily_rollup_bucket_repo_idx")
  @@index([bucketDate, robotId], map: "usage_daily_rollup_bucket_robot_idx")
  @@index([bucketDate, actorUserId], map: "usage_daily_rollup_bucket_actor_idx")
  @@index([bucketDate, provider], map: "usage_daily_rollup_bucket_provider_idx")
}

/// Persist monthly task-usage rollups to support longer-range dashboards without scanning task logs. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model UsageMonthlyRollup {
  id                    String   @id @db.Uuid
  taskId                String   @unique @map("task_id") @db.Uuid
  bucketMonth           DateTime @map("bucket_month") @db.Date
  repoId                String?  @map("repo_id") @db.Uuid
  robotId               String?  @map("robot_id") @db.Uuid
  actorUserId           String?  @map("actor_user_id") @db.Uuid
  provider              String?
  model                 String?
  status                String
  taskCount             Int      @default(1) @map("task_count")
  inputTokens           Int      @default(0) @map("input_tokens")
  outputTokens          Int      @default(0) @map("output_tokens")
  totalTokens           Int      @default(0) @map("total_tokens")
  estimatedCostMicroUsd BigInt   @default(0) @map("estimated_cost_micro_usd")
  durationMs            Int?     @map("duration_ms")
  failed                Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("usage_monthly_rollup")
  @@index([bucketMonth, repoId], map: "usage_monthly_rollup_bucket_repo_idx")
  @@index([bucketMonth, robotId], map: "usage_monthly_rollup_bucket_robot_idx")
  @@index([bucketMonth, actorUserId], map: "usage_monthly_rollup_bucket_actor_idx")
  @@index([bucketMonth, provider], map: "usage_monthly_rollup_bucket_provider_idx")
}

/// Audit quota hits, warnings, degradations, and manual approval events. docs/en/developer/plans/rootfeatureplans20260313/task_plan.md rootfeatureplans20260313
model QuotaEvent {
  id            String   @id @db.Uuid
  budgetPolicyId String? @map("budget_policy_id") @db.Uuid
  taskId        String?  @map("task_id") @db.Uuid
  repoId        String?  @map("repo_id") @db.Uuid
  robotId       String?  @map("robot_id") @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  scopeType     String?  @map("scope_type")
  scopeId       String?  @map("scope_id") @db.Uuid
  eventType     String   @map("event_type")
  decision      String
  message       String   @db.Text
  details       Json?    @map("details_json") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("quota_events")
  @@index([createdAt], map: "quota_events_created_at_idx")
  @@index([taskId, createdAt], map: "quota_events_task_created_at_idx")
  @@index([repoId, createdAt], map: "quota_events_repo_created_at_idx")
  @@index([actorUserId, createdAt], map: "quota_events_actor_created_at_idx")
  @@index([eventType, createdAt], map: "quota_events_event_type_created_at_idx")
}

model TaskGroup {
  id           String   @id @db.Uuid
  repoProvider String?  @map("repo_provider")
  repoId       String?  @map("repo_id") @db.Uuid
  robotId      String?  @map("robot_id") @db.Uuid
  /// Lock task groups to one worker so chat/workspace state stays on a single machine. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  workerId     String?  @map("worker_id") @db.Uuid
  kind         String
  bindingKey   String   @unique @map("binding_key")
  threadId     String?  @map("thread_id")
  title        String?
  issueId      Int?     @map("issue_id")
  mrId         Int?     @map("mr_id")
  commitSha    String?  @map("commit_sha")
  skillSelections Json? @map("skill_selections") // Store per-task-group skill selections as JSON to preserve null inheritance. docs/en/developer/plans/skills-registry-20260225/task_plan.md skills-registry-20260225
  archivedAt   DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tasks        Task[]
  /// Surface task-group worker ownership for chat/task-group routing. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  worker       Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@map("task_groups")
  @@index([repoId, robotId, updatedAt], map: "task_groups_repo_robot_updated_at_idx")
  @@index([archivedAt], map: "task_groups_archived_at_idx")
  /// Speed up worker-scoped task-group status lookups for blocking logic. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  @@index([workerId, updatedAt], map: "task_groups_worker_updated_at_idx")
  /// Accelerate provider activity bindings by indexing repo + provider identifiers. docs/en/developer/plans/repo-page-slow-requests-20260128/task_plan.md repo-page-slow-requests-20260128
  @@index([repoId, commitSha, archivedAt], map: "task_groups_repo_commit_archived_idx")
  @@index([repoId, mrId, archivedAt], map: "task_groups_repo_mr_archived_idx")
  @@index([repoId, issueId, archivedAt], map: "task_groups_repo_issue_archived_idx")
}

/// Store system/audit logs for admin review and diagnostics. docs/en/developer/plans/logs-audit-20260302/task_plan.md logs-audit-20260302
model SystemLog {
  id          String   @id @db.Uuid
  category    String
  level       String
  message     String   @db.Text
  code        String?
  actorUserId String?  @map("actor_user_id") @db.Uuid
  repoId      String?  @map("repo_id") @db.Uuid
  taskId      String?  @map("task_id") @db.Uuid
  taskGroupId String?  @map("task_group_id") @db.Uuid
  meta        Json?    @map("meta_json") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("system_logs")
  @@index([createdAt], map: "system_logs_created_at_idx")
  @@index([category, createdAt], map: "system_logs_category_created_at_idx")
  @@index([level, createdAt], map: "system_logs_level_created_at_idx")
  @@index([actorUserId, createdAt], map: "system_logs_actor_created_at_idx")
  @@index([repoId, createdAt], map: "system_logs_repo_created_at_idx")
  @@index([taskId, createdAt], map: "system_logs_task_created_at_idx")
  @@index([taskGroupId, createdAt], map: "system_logs_task_group_created_at_idx")
}

/// Store per-user notifications for task result alerts. docs/en/developer/plans/notify-panel-20260302/task_plan.md notify-panel-20260302
model Notification {
  id          String   @id @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String
  level       String
  message     String   @db.Text
  code        String?
  repoId      String?  @map("repo_id") @db.Uuid
  taskId      String?  @map("task_id") @db.Uuid
  taskGroupId String?  @map("task_group_id") @db.Uuid
  /// Persist the primary notification target so the UI can navigate with in-app hashes or preserved external URLs. docs/en/developer/plans/cv3zazhx2a716nfc0wn9/task_plan.md cv3zazhx2a716nfc0wn9
  linkUrl     String?  @map("link_url") @db.Text
  meta        Json?    @map("meta_json") @db.JsonB
  readAt      DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
  @@index([userId, createdAt], map: "notifications_user_created_at_idx")
  @@index([userId, readAt], map: "notifications_user_read_at_idx")
  @@index([repoId, createdAt], map: "notifications_repo_created_at_idx")
  @@index([taskId, createdAt], map: "notifications_task_created_at_idx")
}

/// Store global extra skill metadata + prompt injection flags for the skills registry. docs/en/developer/plans/skills-registry-20260225/task_plan.md skills-registry-20260225
model ExtraSkill {
  id            String   @id @db.Uuid // Extra skills use app-generated UUIDs for consistent ID creation. docs/en/developer/plans/skills-registry-20260225/task_plan.md skills-registry-20260225
  slug          String   @unique
  displayName   String   @map("display_name")
  description   String?
  version       String?
  enabled       Boolean  @default(true)
  promptText    String?  @map("prompt_text") @db.Text
  promptEnabled Boolean  @default(false) @map("prompt_enabled")
  tags          String[] @default([]) @map("tags") // Store skill tags for filtering in the console UI. docs/en/developer/plans/skills-registry-20260225/task_plan.md skills-registry-20260225
  storagePath   String   @map("storage_path")
  checksum      String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("extra_skills")
  @@index([enabled, createdAt], map: "extra_skills_enabled_created_at_idx")
}

model User {
  id               String   @id @db.Uuid
  username         String
  usernameLower    String   @unique @map("username_lower")
  /// Track login email + verification status for registration flow. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
  email            String?  @map("email")
  emailLower       String?  @unique @map("email_lower")
  displayName      String?  @map("display_name")
  modelCredentials Json?    @map("model_credentials_json") @db.JsonB
  passwordHash     String   @map("password_hash")
  passwordSalt     String   @map("password_salt")
  disabled         Boolean  @default(false)
  /// Store roles for global RBAC checks (e.g., admin). docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
  emailVerifiedAt  DateTime? @map("email_verified_at") @db.Timestamptz(6)
  roles            String[] @default([]) @map("roles")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  /// Link PAT records back to the owning account. docs/en/developer/plans/open-api-pat-design/task_plan.md open-api-pat-design
  apiTokens        UserApiToken[]
  /// Link repo membership and invite relationships to users. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
  repoMemberships  RepoMember[]
  repoInvitesSent  RepoMemberInvite[] @relation("RepoMemberInviteInvitedBy")
  repoInvitesReceived RepoMemberInvite[] @relation("RepoMemberInviteInvitedUser")
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

/// Persist user-scoped PAT metadata for API access. docs/en/developer/plans/open-api-pat-design/task_plan.md open-api-pat-design
model UserApiToken {
  id         String    @id @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  tokenHash  String    @map("token_hash")
  tokenPrefix String   @map("token_prefix")
  tokenLast4 String?   @map("token_last4")
  scopes     Json      @map("scopes_json") @db.JsonB
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  lastUsedIp String?   @map("last_used_ip")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_tokens")
  @@unique([tokenHash], map: "user_api_tokens_token_hash_unique")
  @@index([userId, createdAt], map: "user_api_tokens_user_created_at_idx")
}

model Repository {
  id                     String   @id @db.Uuid
  provider               String
  name                   String
  externalId             String?  @map("external_id")
  apiBaseUrl             String?  @map("api_base_url")
  branches               Json?    @map("branches_json") @db.JsonB
  webhookSecret          String?  @map("webhook_secret")
  repoProviderCredentials  Json?  @map("repo_provider_credentials_json") @db.JsonB
  modelProviderCredentials Json?  @map("model_provider_credentials_json") @db.JsonB
  previewEnv             Json?    @map("preview_env_json") @db.JsonB // Store repo-scoped preview env vars (secrets redacted in API). docs/en/developer/plans/preview-env-config-20260302/task_plan.md preview-env-config-20260302
  webhookVerifiedAt      DateTime? @map("webhook_verified_at") @db.Timestamptz(6)
  archivedAt             DateTime? @map("archived_at") @db.Timestamptz(6)
  skillDefaults          Json?    @map("skill_defaults") // Store repo-level default skills as JSON to preserve null semantics. docs/en/developer/plans/skills-registry-20260225/task_plan.md skills-registry-20260225
  enabled                Boolean  @default(true)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  robots           RepoRobot[]
  /// Attach repo members and pending invites for RBAC controls. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
  members          RepoMember[]
  invites          RepoMemberInvite[]
  automationConfig RepoAutomationConfig?
  webhookDeliveries RepoWebhookDelivery[]

  @@map("repositories")
  @@unique([provider, externalId], map: "repositories_provider_external_unique")
  @@index([archivedAt], map: "repositories_archived_at_idx")
}

/// Store per-repo membership roles for RBAC enforcement. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
model RepoMember {
  id        String   @id @db.Uuid
  repoId    String   @map("repo_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  repo Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repo_members")
  @@unique([repoId, userId], map: "repo_members_repo_user_unique")
  @@index([userId], map: "repo_members_user_id_idx")
}

/// Persist repo member invites until accepted/revoked. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
model RepoMemberInvite {
  id              String    @id @db.Uuid
  repoId          String    @map("repo_id") @db.Uuid
  email           String
  emailLower      String    @map("email_lower")
  role            String
  tokenHash       String    @map("token_hash")
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  invitedUserId   String?   @map("invited_user_id") @db.Uuid
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  repo Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  invitedBy User @relation("RepoMemberInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser User? @relation("RepoMemberInviteInvitedUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@map("repo_member_invites")
  @@index([repoId], map: "repo_member_invites_repo_id_idx")
  @@index([emailLower], map: "repo_member_invites_email_idx")
  @@index([tokenHash], map: "repo_member_invites_token_hash_idx")
}

/// Track email verification tokens for registration. docs/en/developer/plans/multiuserauth20260226/task_plan.md multiuserauth20260226
model EmailVerificationToken {
  id         String    @id @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  email      String
  emailLower String    @map("email_lower")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
  @@index([userId], map: "email_verification_tokens_user_id_idx")
  @@index([emailLower], map: "email_verification_tokens_email_idx")
  @@unique([tokenHash], map: "email_verification_tokens_token_hash_unique")
}

model RepoWebhookDelivery {
  id         String   @id @db.Uuid
  repoId     String   @map("repo_id") @db.Uuid
  provider   String
  eventName  String?  @map("event_name")
  deliveryId String?  @map("delivery_id")
  /// Persist the normalized HookCode event type so replay/debug views do not need to re-parse payloads. docs/en/developer/plans/webhook-replay-debug-20260313/task_plan.md webhook-replay-debug-20260313
  mappedEventType String? @map("mapped_event_type")
  result     String
  httpStatus Int      @map("http_status")
  code       String?
  message    String?
  /// Store payload hashes and verification outcomes for replay/debug filtering without reading full payload JSON. docs/en/developer/plans/webhook-replay-debug-20260313/task_plan.md webhook-replay-debug-20260313
  payloadHash String?  @map("payload_hash")
  signatureVerified Boolean? @map("signature_verified")
  errorLayer String? @map("error_layer")
  /// Persist matched rule/robot/task-group ids so debug center summaries can link automation decisions and replay results. docs/en/developer/plans/webhook-replay-debug-20260313/task_plan.md webhook-replay-debug-20260313
  matchedRuleIds String[] @default([]) @map("matched_rule_ids")
  matchedRobotIds String[] @default([]) @map("matched_robot_ids")
  taskIds    String[] @default([]) @map("task_ids")
  taskGroupIds String[] @default([]) @map("task_group_ids")
  /// Link replay/dry-run events back to the original webhook event while keeping history append-only. docs/en/developer/plans/webhook-replay-debug-20260313/task_plan.md webhook-replay-debug-20260313
  replayOfEventId String? @map("replay_of_event_id") @db.Uuid
  replayMode String? @map("replay_mode")
  payload    Json?    @map("payload_json") @db.JsonB
  response   Json?    @map("response_json") @db.JsonB
  debugTrace Json?    @map("debug_trace_json") @db.JsonB
  dryRunResult Json?  @map("dry_run_result_json") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  repo Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@map("repo_webhook_deliveries")
  @@index([repoId, createdAt], map: "repo_webhook_deliveries_repo_id_created_at_idx")
  /// Support cursor pagination for repo webhook delivery lists. docs/en/developer/plans/repo-page-slow-requests-20260128/task_plan.md repo-page-slow-requests-20260128
  @@index([repoId, createdAt, id], map: "repo_webhook_deliveries_repo_created_id_idx")
  /// Accelerate global replay/debug center filters by failure layer and replay lineage. docs/en/developer/plans/webhook-replay-debug-20260313/task_plan.md webhook-replay-debug-20260313
  @@index([result, createdAt], map: "repo_webhook_deliveries_result_created_at_idx")
  @@index([errorLayer, createdAt], map: "repo_webhook_deliveries_error_layer_created_at_idx")
  @@index([replayOfEventId, createdAt], map: "repo_webhook_deliveries_replay_of_event_created_at_idx")
  @@index([payloadHash], map: "repo_webhook_deliveries_payload_hash_idx")
}

model RepoRobot {
  id                    String    @id @db.Uuid
  repoId                String    @map("repo_id") @db.Uuid
  /// Persist the default worker override for this robot when tasks should avoid the local worker. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  defaultWorkerId       String?   @map("default_worker_id") @db.Uuid
  name                  String
  permission            String
  token                 String?
  cloneUsername         String?   @map("clone_username")
  repoCredentialProfileId String? @map("repo_credential_profile_id")
  repoCredentialSource  String?   @map("repo_credential_source")
  repoCredentialRemark  String?   @map("repo_credential_remark")
  repoTokenUserId       String?   @map("repo_token_user_id")
  repoTokenUsername     String?   @map("repo_token_username")
  repoTokenUserName     String?   @map("repo_token_user_name")
  repoTokenUserEmail    String?   @map("repo_token_user_email")
  repoTokenRepoRole     String?   @map("repo_token_repo_role")
  repoTokenRepoRoleJson Json?     @map("repo_token_repo_role_json") @db.JsonB
  /// Store explicit robot workflow mode (auto/direct/fork) for repo pull control. docs/en/developer/plans/robotpullmode20260124/task_plan.md robotpullmode20260124
  repoWorkflowMode      String?   @map("repo_workflow_mode")
  /// Store robot-level time windows for hour-based execution scheduling. docs/en/developer/plans/timewindowtask20260126/task_plan.md timewindowtask20260126
  timeWindowStartHour   Int?      @map("time_window_start_hour")
  /// Store robot-level time windows for hour-based execution scheduling. docs/en/developer/plans/timewindowtask20260126/task_plan.md timewindowtask20260126
  timeWindowEndHour     Int?      @map("time_window_end_hour")
  promptDefault         String?   @map("prompt_default")
  language              String?
  modelProvider         String    @default("codex") @map("model_provider")
  modelProviderConfig   Json?     @map("model_provider_config_json") @db.JsonB
  /// Store dependency management overrides per robot. docs/en/developer/plans/depmanimpl20260124/task_plan.md depmanimpl20260124
  dependencyConfig      Json?     @map("dependency_config_json") @db.JsonB
  defaultBranchRole     String?   @map("default_branch_role")
  defaultBranch         String?   @map("default_branch")
  activatedAt           DateTime? @map("activated_at") @db.Timestamptz(6)
  lastTestAt            DateTime? @map("last_test_at") @db.Timestamptz(6)
  lastTestOk            Boolean?  @map("last_test_ok")
  lastTestMessage       String?   @map("last_test_message")
  enabled               Boolean   @default(false)
  isDefault             Boolean   @default(false) @map("is_default")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  repo Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  /// Link robots to their preferred worker for effective worker resolution. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  defaultWorker Worker? @relation("RepoRobotDefaultWorker", fields: [defaultWorkerId], references: [id], onDelete: SetNull)

  @@map("repo_robots")
  @@index([repoId], map: "repo_robots_repo_id_idx")
  /// Speed up worker-filtered robot lists in the repo settings UI. docs/en/developer/plans/worker-executor-refactor-20260307/task_plan.md worker-executor-refactor-20260307
  @@index([defaultWorkerId], map: "repo_robots_default_worker_id_idx")
}

model GlobalRobot {
  id                    String    @id @db.Uuid
  /// Persist the default worker override for globally shared robots so cross-repo tasks can target remote executors. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  defaultWorkerId       String?   @map("default_worker_id") @db.Uuid
  name                  String
  permission            String
  /// Allow global robots to reference global/user/repo provider credentials without embedding repo-specific tokens. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  repoCredentialProfileId String? @map("repo_credential_profile_id")
  repoCredentialSource  String?   @map("repo_credential_source")
  /// Store explicit robot workflow mode (auto/direct/fork) for repo pull control. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  repoWorkflowMode      String?   @map("repo_workflow_mode")
  /// Store robot-level time windows for hour-based execution scheduling. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  timeWindowStartHour   Int?      @map("time_window_start_hour")
  /// Store robot-level time windows for hour-based execution scheduling. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  timeWindowEndHour     Int?      @map("time_window_end_hour")
  promptDefault         String?   @map("prompt_default")
  language              String?
  modelProvider         String    @default("codex") @map("model_provider")
  modelProviderConfig   Json?     @map("model_provider_config_json") @db.JsonB
  /// Store dependency management overrides per global robot. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  dependencyConfig      Json?     @map("dependency_config_json") @db.JsonB
  defaultBranchRole     String?   @map("default_branch_role")
  defaultBranch         String?   @map("default_branch")
  enabled               Boolean   @default(true)
  isDefault             Boolean   @default(false) @map("is_default")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  /// Link globally shared robots to their preferred worker for effective worker resolution. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  defaultWorker Worker? @relation("GlobalRobotDefaultWorker", fields: [defaultWorkerId], references: [id], onDelete: SetNull)

  @@map("global_robots")
  @@index([enabled, createdAt], map: "global_robots_enabled_created_at_idx")
  @@index([isDefault, permission], map: "global_robots_default_permission_idx")
  @@index([defaultWorkerId], map: "global_robots_default_worker_id_idx")
}

model GlobalCredentialSettings {
  id                     String   @id
  /// Store global provider-token profiles so admin-managed robots can resolve repo/model credentials without per-repo setup. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  repoProviderCredentials Json?   @map("repo_provider_credentials_json") @db.JsonB
  /// Store global model-provider API key profiles for shared robot execution. docs/en/developer/plans/52d0x2aa8umrjgjklgwa/task_plan.md 52d0x2aa8umrjgjklgwa
  modelProviderCredentials Json?  @map("model_provider_credentials_json") @db.JsonB
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("global_credential_settings")
}

/// Track local and remote execution workers that can receive HookCode tasks.
/// v2: HTTP Pull architecture — workers poll for tasks, authenticate via API key.
model Worker {
  id                 String    @id @db.Uuid
  name               String
  kind               String    /// 'local' | 'remote'
  status             String    /// 'online' | 'offline' | 'disabled'
  systemManaged      Boolean   @default(false) @map("system_managed")
  isGlobalDefault    Boolean   @default(false) @map("is_global_default")
  version            String?
  platform           String?
  arch               String?
  hostname           String?
  /// API key hash for worker authentication (replaces bind-code + WebSocket token)
  apiKeyHash         String?   @map("api_key_hash")
  /// Prefix for display (e.g. "hkw_abc...")
  apiKeyPrefix       String?   @map("api_key_prefix")
  /// Supported AI providers: codex, claude_code, gemini_cli
  providers          String[]  @default([]) @map("providers")
  capabilities       Json?     @map("capabilities_json") @db.JsonB
  maxConcurrency     Int       @default(1) @map("max_concurrency")
  activeTaskCount    Int       @default(0) @map("active_task_count")
  lastHeartbeatAt    DateTime? @map("last_heartbeat_at") @db.Timestamptz(6)
  disabledAt         DateTime? @map("disabled_at") @db.Timestamptz(6)
  createdByUserId    String?   @map("created_by_user_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  tasks        Task[]
  taskGroups   TaskGroup[]
  defaultRobots RepoRobot[] @relation("RepoRobotDefaultWorker")
  defaultGlobalRobots GlobalRobot[] @relation("GlobalRobotDefaultWorker")

  @@map("workers")
  @@index([status, updatedAt], map: "workers_status_updated_at_idx")
  @@index([kind, updatedAt], map: "workers_kind_updated_at_idx")
  @@index([lastHeartbeatAt], map: "workers_last_heartbeat_at_idx")
  @@index([apiKeyHash], map: "workers_api_key_hash_idx")
}

model RepoAutomationConfig {
  repoId     String   @id @map("repo_id") @db.Uuid
  config     Json     @map("config_json") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  repo       Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@map("repo_automation_configs")
}
